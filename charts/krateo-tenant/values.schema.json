{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "authMethod": {
      "default": "basic",
      "description": "Authentication method for child Krateo",
      "enum": [
        "basic",
        "oidc",
        "ldap"
      ],
      "title": "authMethod",
      "type": "string"
    },
    "features": {
      "additionalProperties": false,
      "description": "Feature toggles",
      "properties": {
        "composableoperations": {
          "default": true,
          "description": "Enable Composable Operations",
          "title": "composableoperations",
          "type": "boolean"
        },
        "composableportal": {
          "default": true,
          "description": "Enable Composable Portal",
          "title": "composableportal",
          "type": "boolean"
        },
        "finops": {
          "default": false,
          "description": "Enable FinOps module",
          "title": "finops",
          "type": "boolean"
        }
      },
      "title": "features",
      "type": "object"
    },
    "global": {
      "additionalProperties": false,
      "description": "global properties section - injected by Composition Dynamic Controller",
      "properties": {
        "compositionName": {
          "default": "",
          "description": "Composition Custom Resource metadata name",
          "title": "compositionName",
          "type": "string"
        }
      },
      "title": "global",
      "type": "object"
    },
    "krateoVersion": {
      "default": "2.7.0",
      "description": "Krateo version to install inside the vCluster",
      "title": "krateoVersion",
      "type": "string"
    },
    "plan": {
      "default": "free",
      "description": "Plan tier",
      "enum": [
        "free",
        "starter",
        "professional",
        "enterprise"
      ],
      "title": "plan",
      "type": "string"
    },
    "tenantName": {
      "default": "",
      "description": "Tenant name",
      "title": "tenantName",
      "type": "string"
    },
    "vcluster": {
      "additionalProperties": false,
      "description": "vCluster subchart configuration",
      "properties": {
        "experimental": {
          "additionalProperties": false,
          "properties": {
            "deploy": {
              "additionalProperties": false,
              "properties": {
                "vcluster": {
                  "additionalProperties": false,
                  "properties": {
                    "helm": {
                      "items": {
                        "anyOf": [
                          {
                            "additionalProperties": false,
                            "properties": {
                              "chart": {
                                "additionalProperties": false,
                                "properties": {
                                  "name": {
                                    "default": "installer",
                                    "title": "name",
                                    "type": "string"
                                  },
                                  "repo": {
                                    "default": "https://charts.krateo.io",
                                    "title": "repo",
                                    "type": "string"
                                  },
                                  "version": {
                                    "default": "2.7.0",
                                    "title": "version",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "name",
                                  "repo",
                                  "version"
                                ],
                                "title": "chart",
                                "type": "object"
                              },
                              "release": {
                                "additionalProperties": false,
                                "properties": {
                                  "name": {
                                    "default": "krateo",
                                    "title": "name",
                                    "type": "string"
                                  },
                                  "namespace": {
                                    "default": "krateo-system",
                                    "title": "namespace",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "name",
                                  "namespace"
                                ],
                                "title": "release",
                                "type": "object"
                              },
                              "values": {
                                "default": "krateoplatformops:\n  composableportal:\n    enabled: true\n  composableoperations:\n    enabled: true\n  composablefinops:\n    enabled: false\n  service:\n    type: ClusterIP\n    externalIpAvailable: false\n  ingress:\n    enabled: true",
                                "title": "values",
                                "type": "string"
                              }
                            },
                            "required": [
                              "chart",
                              "values",
                              "release"
                            ],
                            "type": "object"
                          }
                        ]
                      },
                      "title": "helm",
                      "type": "array"
                    }
                  },
                  "required": [
                    "helm"
                  ],
                  "title": "vcluster",
                  "type": "object"
                }
              },
              "required": [
                "vcluster"
              ],
              "title": "deploy",
              "type": "object"
            }
          },
          "required": [
            "deploy"
          ],
          "title": "experimental",
          "type": "object"
        },
        "sync": {
          "additionalProperties": false,
          "properties": {
            "toHost": {
              "additionalProperties": false,
              "properties": {
                "ingresses": {
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "default": true,
                      "title": "enabled",
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "enabled"
                  ],
                  "title": "ingresses",
                  "type": "object"
                }
              },
              "required": [
                "ingresses"
              ],
              "title": "toHost",
              "type": "object"
            }
          },
          "required": [
            "toHost"
          ],
          "title": "sync",
          "type": "object"
        }
      },
      "required": [
        "sync",
        "experimental"
      ],
      "title": "vcluster",
      "type": "object"
    }
  },
  "required": [
    "tenantName",
    "plan",
    "authMethod",
    "krateoVersion",
    "features",
    "vcluster"
  ],
  "type": "object"
}