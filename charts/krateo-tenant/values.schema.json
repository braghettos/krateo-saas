{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": true,
  "properties": {
    "authMethod": {
      "default": "basic",
      "description": "Authentication method for child Krateo",
      "enum": [
        "basic",
        "oidc",
        "ldap"
      ],
      "title": "authMethod",
      "type": "string"
    },
    "features": {
      "additionalProperties": false,
      "description": "Feature toggles",
      "properties": {
        "composableoperations": {
          "default": true,
          "description": "Enable Composable Operations",
          "title": "composableoperations",
          "type": "boolean"
        },
        "composableportal": {
          "default": true,
          "description": "Enable Composable Portal",
          "title": "composableportal",
          "type": "boolean"
        },
        "finops": {
          "default": false,
          "description": "Enable FinOps module",
          "title": "finops",
          "type": "boolean"
        }
      },
      "title": "features",
      "type": "object"
    },
    "global": {
      "additionalProperties": true,
      "description": "global properties section - injected by Composition Dynamic Controller",
      "properties": {
        "compositionName": {
          "default": "",
          "description": "Composition Custom Resource metadata name",
          "title": "compositionName",
          "type": "string"
        }
      },
      "title": "global",
      "type": "object"
    },
    "krateoVersion": {
      "default": "2.7.0",
      "description": "Krateo version to install inside the vCluster",
      "title": "krateoVersion",
      "type": "string"
    },
    "plan": {
      "default": "free",
      "description": "Plan tier",
      "enum": [
        "free",
        "starter",
        "professional",
        "enterprise"
      ],
      "title": "plan",
      "type": "string"
    },
    "tenantName": {
      "default": "",
      "description": "Tenant name",
      "title": "tenantName",
      "type": "string"
    },
    "vcluster": {
      "additionalProperties": true,
      "description": "vCluster subchart configuration",
      "title": "vcluster",
      "type": "object"
    }
  },
  "required": [
    "tenantName",
    "plan",
    "authMethod",
    "krateoVersion",
    "features"
  ],
  "type": "object"
}
